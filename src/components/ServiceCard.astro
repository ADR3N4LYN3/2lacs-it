---
/** Carte d'une prestation : lien vers la page détail. Aucune donnée en dur. */
import Icon from '@/components/Icon.astro';

interface Props {
  title: string;
  summary: string;
  href: string;
  icon: string;
}

const { title, summary, href, icon } = Astro.props;
---

<a
  href={href}
  class="group relative flex flex-col overflow-hidden rounded-2xl border border-brand-100 bg-white p-6 transition duration-300 hover:-translate-y-1 hover:border-accent-300 hover:shadow-xl hover:shadow-brand-900/5"
>
  <span
    class="absolute inset-x-0 top-0 h-1 origin-left scale-x-0 bg-gradient-to-r from-accent-300 via-accent-400 to-accent-600 transition-transform duration-300 group-hover:scale-x-100"
  ></span>

  <span
    class="inline-flex h-12 w-12 items-center justify-center rounded-xl bg-brand-900 text-accent-300 transition-colors duration-300 group-hover:bg-gradient-to-br group-hover:from-accent-300 group-hover:to-accent-500 group-hover:text-brand-900"
  >
    <Icon name={icon} class="h-6 w-6" />
  </span>

  <h3 class="mt-5 font-display text-lg font-semibold text-brand-900">{title}</h3>
  <p class="mt-2 flex-1 text-sm leading-relaxed text-brand-700/80">{summary}</p>

  <span class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-accent-600">
    En savoir plus
    <span class="transition-transform duration-300 group-hover:translate-x-1" aria-hidden="true"
      >→</span
    >
  </span>
</a>
