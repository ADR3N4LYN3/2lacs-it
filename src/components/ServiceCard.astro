---
/** Carte d'une prestation. Reçoit un Service typé, ne contient aucune donnée en dur. */
import type { Service } from '@/lib/services';

type Props = Pick<Service, 'title' | 'summary'>;

const { title, summary } = Astro.props;
---

<article
  class="rounded-xl border border-brand-100 bg-white p-6 shadow-sm transition hover:border-brand-300 hover:shadow-md"
>
  <h3 class="text-lg font-semibold text-brand-700">{title}</h3>
  <p class="mt-2 text-sm leading-relaxed text-brand-900/70">{summary}</p>
</article>
