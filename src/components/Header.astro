---
/** En-tête : logo réel + navigation + bascule de thème. Données issues de site-config. */
import { Image } from 'astro:assets';
import { siteConfig } from '@/lib/site-config';
import ThemeToggle from '@/components/ThemeToggle.astro';
import logo from '@/assets/logo-2lacs.png';

const { nav } = siteConfig;
const links = nav.filter((i) => i.label !== 'Contact');
---

<header class="sticky top-0 z-50 border-b border-edge/70 bg-surface/85 backdrop-blur-md">
  <nav class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-6 py-3">
    <a href="/" class="shrink-0" aria-label="2 LACS Informatique, accueil">
      <Image
        src={logo}
        alt="2 LACS Informatique"
        height={72}
        class="h-9 w-auto dark:brightness-0 dark:invert"
      />
    </a>

    <div class="hidden items-center gap-7 md:flex">
      <ul class="flex items-center gap-7 text-sm font-medium">
        {
          links.map((item) => (
            <li>
              <a
                class="group relative py-1 text-muted transition-colors hover:text-content"
                href={item.href}
              >
                {item.label}
                <span class="absolute -bottom-0.5 left-0 h-0.5 w-0 bg-accent-400 transition-all duration-300 group-hover:w-full" />
              </a>
            </li>
          ))
        }
      </ul>
      <ThemeToggle />
      <a
        href="/contact"
        class="rounded-full bg-content px-5 py-2 text-sm font-semibold text-surface shadow-sm transition hover:opacity-90"
      >
        Contact
      </a>
    </div>

    <div class="flex items-center gap-2 md:hidden">
      <ThemeToggle />
      <details class="relative">
        <summary
          class="flex h-9 w-9 cursor-pointer list-none items-center justify-center rounded-full border border-edge text-content [&::-webkit-details-marker]:hidden"
          aria-label="Ouvrir le menu"
        >
          <svg
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            aria-hidden="true"
          >
            <line x1="3" y1="6" x2="21" y2="6"></line>
            <line x1="3" y1="12" x2="21" y2="12"></line>
            <line x1="3" y1="18" x2="21" y2="18"></line>
          </svg>
        </summary>
        <ul class="absolute right-0 mt-2 w-52 rounded-xl border border-edge bg-card p-2 shadow-xl">
          {
            nav.map((item) => (
              <li>
                <a
                  class="block rounded-lg px-3 py-2 text-sm font-medium text-content hover:bg-panel"
                  href={item.href}
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </details>
    </div>
  </nav>
</header>
