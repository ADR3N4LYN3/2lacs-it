---
/** Bandeau d'accueil. Contenu paramétrable via props, valeurs par défaut depuis site-config. */
import { siteConfig } from '@/lib/site-config';

interface Props {
  title?: string;
  subtitle?: string;
}

const { title = siteConfig.tagline, subtitle = siteConfig.description } = Astro.props;
---

<section
  class="relative overflow-hidden bg-gradient-to-br from-brand-700 via-brand-600 to-accent-500 text-white"
>
  <div class="mx-auto max-w-6xl px-6 py-24 sm:py-32">
    <h1 class="max-w-3xl text-4xl font-bold leading-tight tracking-tight sm:text-5xl">{title}</h1>
    <p class="mt-6 max-w-2xl text-lg text-white/90">{subtitle}</p>
    <div class="mt-10 flex flex-wrap gap-4">
      <a
        href="/contact"
        class="rounded-lg bg-white px-6 py-3 text-sm font-semibold text-brand-700 shadow-sm transition hover:bg-brand-50"
      >
        Nous contacter
      </a>
      <a
        href="/#services"
        class="rounded-lg border border-white/40 px-6 py-3 text-sm font-semibold text-white transition hover:bg-white/10"
      >
        Nos services
      </a>
    </div>
  </div>
</section>
