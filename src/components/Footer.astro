---
/** Pied de page : identité + navigation + contact + liens légaux. Données issues de site-config. */
import { Image } from 'astro:assets';
import { siteConfig } from '@/lib/site-config';
import mark from '@/assets/logo-mark.png';

const { name, tagline, contact, supportUrl, nav, legal, social } = siteConfig;
const year = new Date().getFullYear();
---

<footer class="relative isolate overflow-hidden bg-brand-900 text-paper/80">
  <div class="topo absolute inset-0"></div>

  <div class="relative mx-auto max-w-6xl px-6">
    <div class="grid gap-10 py-14 sm:grid-cols-2 lg:grid-cols-4">
      <div>
        <div class="flex items-center gap-2.5">
          <Image src={mark} alt="" aria-hidden="true" width={64} class="h-8 w-auto" />
          <span class="font-display text-lg font-bold text-paper">
            2 LACS<span class="text-paper/50"> Informatique</span>
          </span>
        </div>
        <p class="mt-3 max-w-xs text-sm text-paper/60">{tagline}</p>
        <ul class="mt-5 flex flex-wrap gap-2">
          {
            social.map((s) => (
              <li>
                <a
                  class="rounded-full border border-paper/15 px-3 py-1 text-xs font-medium text-paper/70 transition hover:border-accent-400 hover:text-accent-300"
                  href={s.href}
                  rel="noopener"
                >
                  {s.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <nav aria-label="Navigation de pied de page" class="text-sm">
        <p class="text-xs font-semibold tracking-[0.14em] text-paper/45 uppercase">Navigation</p>
        <ul class="mt-4 space-y-2.5">
          {
            nav.map((item) => (
              <li>
                <a class="text-paper/70 transition hover:text-accent-300" href={item.href}>
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <div class="text-sm">
        <p class="text-xs font-semibold tracking-[0.14em] text-paper/45 uppercase">Contact</p>
        <ul class="mt-4 space-y-2.5">
          <li>
            <a class="text-accent-300 hover:underline" href={`mailto:${contact.email}`}>
              {contact.email}
            </a>
          </li>
          <li>
            <a
              class="text-paper/70 transition hover:text-accent-300"
              href={supportUrl}
              rel="noopener"
            >
              Portail support
            </a>
          </li>
          <li class="text-paper/55">Entrelacs (73) · Savoie</li>
        </ul>
      </div>

      <nav aria-label="Informations légales" class="text-sm">
        <p class="text-xs font-semibold tracking-[0.14em] text-paper/45 uppercase">Informations</p>
        <ul class="mt-4 space-y-2.5">
          {
            legal.map((item) => (
              <li>
                <a class="text-paper/70 transition hover:text-accent-300" href={item.href}>
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </div>

    <div
      class="flex flex-col items-center justify-between gap-2 border-t border-paper/10 py-6 text-xs text-paper/45 sm:flex-row"
    >
      <p>© {year} {name} — Entrelacs, Savoie</p>
      <p>SIRET 978&nbsp;059&nbsp;830&nbsp;00015</p>
    </div>
  </div>
</footer>
