---
/** Pied de page : identité + navigation + contact + liens légaux. Données issues de site-config. */
import { siteConfig } from '@/lib/site-config';

const { name, tagline, contact, supportUrl, nav, legal, social } = siteConfig;
const year = new Date().getFullYear();
---

<footer class="border-t border-brand-100 bg-brand-50">
  <div class="mx-auto grid max-w-6xl gap-10 px-6 py-14 sm:grid-cols-2 lg:grid-cols-4">
    <div>
      <p class="text-base font-bold text-brand-700">{name}</p>
      <p class="mt-2 text-sm text-brand-900/70">{tagline}</p>
      <ul class="mt-4 flex gap-4 text-sm">
        {
          social.map((s) => (
            <li>
              <a class="text-brand-600 hover:underline" href={s.href} rel="noopener">
                {s.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <nav aria-label="Navigation de pied de page" class="text-sm">
      <p class="font-semibold text-brand-900">Navigation</p>
      <ul class="mt-3 space-y-2">
        {
          nav.map((item) => (
            <li>
              <a class="text-brand-900/70 hover:text-brand-600" href={item.href}>
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="text-sm">
      <p class="font-semibold text-brand-900">Contact</p>
      <ul class="mt-3 space-y-2">
        <li>
          <a class="text-brand-600 hover:underline" href={`mailto:${contact.email}`}>
            {contact.email}
          </a>
        </li>
        <li>
          <a class="text-brand-900/70 hover:text-brand-600" href={supportUrl} rel="noopener">
            Portail support
          </a>
        </li>
      </ul>
    </div>

    <nav aria-label="Informations légales" class="text-sm">
      <p class="font-semibold text-brand-900">Informations</p>
      <ul class="mt-3 space-y-2">
        {
          legal.map((item) => (
            <li>
              <a class="text-brand-900/70 hover:text-brand-600" href={item.href}>
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>

  <div class="border-t border-brand-100 px-6 py-4 text-center text-xs text-brand-900/60">
    © {year}
    {name} — {tagline}
  </div>
</footer>
