---
/**
 * Shell HTML de toutes les pages (orchestrateur de mise en page).
 * Compose <head> SEO + Header + slot + Footer. Aucune logique métier.
 */
import '@fontsource-variable/bricolage-grotesque';
import '@fontsource-variable/hanken-grotesk';
import '../styles/global.css';
import SEO from '@/components/SEO.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { siteConfig } from '@/lib/site-config';
import type { SeoInput } from '@/lib/seo';

type Props = SeoInput;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    {/* Applique le thème AVANT le paint pour éviter tout flash (FOUC). */}
    <script is:inline>
      (() => {
        try {
          const t = localStorage.getItem('theme');
          if (t === 'dark' || (!t && matchMedia('(prefers-color-scheme: dark)').matches))
            document.documentElement.classList.add('dark');
        } catch {
          /* stockage indisponible : on ignore */
        }
      })();
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <SEO {...Astro.props} />
  </head>
  <body class="flex min-h-screen flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
    <link rel="me" href={siteConfig.url} />
    {/* Bascule de thème (délégation : couvre tous les boutons [data-theme-toggle]). */}
    <script is:inline>
      addEventListener('click', (e) => {
        if (!e.target.closest('[data-theme-toggle]')) return;
        const dark = document.documentElement.classList.toggle('dark');
        try {
          localStorage.setItem('theme', dark ? 'dark' : 'light');
        } catch {
          /* stockage indisponible : on ignore */
        }
      });
    </script>
  </body>
</html>
