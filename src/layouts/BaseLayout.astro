---
/**
 * Shell HTML de toutes les pages (orchestrateur de mise en page).
 * Compose <head> SEO + Header + slot + Footer.
 * Navigation client : View Transitions (crossfade) + barre de chargement (cf. plus bas).
 */
import '@fontsource-variable/bricolage-grotesque';
import '@fontsource-variable/hanken-grotesk';
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import SEO from '@/components/SEO.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { siteConfig } from '@/lib/site-config';
import type { SeoInput } from '@/lib/seo';

type Props = SeoInput;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    {
      /* Thème appliqué AVANT le paint (anti-FOUC) + réappliqué après chaque navigation client
        (les View Transitions réinitialisent la classe de <html> avec celle de la page statique). */
    }
    <script is:inline>
      (() => {
        const apply = () => {
          let dark = false;
          try {
            const t = localStorage.getItem('theme');
            dark = t === 'dark' || (!t && matchMedia('(prefers-color-scheme: dark)').matches);
          } catch {
            /* stockage indisponible : on ignore */
          }
          document.documentElement.classList.toggle('dark', dark);
        };
        apply();
        document.addEventListener('astro:after-swap', apply);
      })();
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="generator" content={Astro.generator} />
    <SEO {...Astro.props} />
    <ClientRouter />
  </head>
  <body class="flex min-h-screen flex-col">
    {/* Barre de chargement (persistée entre navigations, pilotée par le script en bas). */}
    <div
      id="loadbar"
      transition:persist
      aria-hidden="true"
      class="fixed inset-x-0 top-0 z-[100] h-[3px] origin-left scale-x-0 bg-gradient-to-r from-accent-300 via-accent-400 to-accent-600 opacity-0"
    >
    </div>

    <Header transition:persist />
    <main class="flex-1">
      <slot />
    </main>
    <Footer transition:persist />
    <link rel="me" href={siteConfig.url} />

    {/* Bascule de thème (délégation ; gardée pour ne pas doublonner avec la nav client). */}
    <script is:inline>
      if (!window.__themeToggleBound) {
        window.__themeToggleBound = true;
        addEventListener('click', (e) => {
          if (!e.target.closest('[data-theme-toggle]')) return;
          const dark = document.documentElement.classList.toggle('dark');
          try {
            localStorage.setItem('theme', dark ? 'dark' : 'light');
          } catch {
            /* stockage indisponible : on ignore */
          }
        });
      }
    </script>

    {/* Barre de chargement + petit délai volontaire pour rendre la transition perceptible. */}
    <script>
      const DELAY = 450; // ms — ajuster ici pour accélérer / ralentir
      const bar = document.getElementById('loadbar');

      if (bar) {
        let navigating = false;
        let hideTimer: ReturnType<typeof setTimeout>;

        const startBar = () => {
          clearTimeout(hideTimer);
          bar.style.transition = 'none';
          bar.style.opacity = '1';
          bar.style.transform = 'scaleX(0.02)';
          bar.getBoundingClientRect(); // force le reflow
          bar.style.transition = `transform ${DELAY}ms cubic-bezier(0.25, 0.8, 0.3, 1)`;
          bar.style.transform = 'scaleX(0.9)';
        };

        const finishBar = () => {
          bar.style.transition = 'transform 0.2s ease-out';
          bar.style.transform = 'scaleX(1)';
          hideTimer = setTimeout(() => {
            bar.style.transition = 'opacity 0.35s ease';
            bar.style.opacity = '0';
            setTimeout(() => {
              bar.style.transform = 'scaleX(0)';
            }, 360);
          }, 220);
        };

        document.addEventListener('astro:before-preparation', (e) => {
          navigating = true;
          startBar();
          const load = e.loader;
          e.loader = async () => {
            await new Promise((r) => setTimeout(r, DELAY));
            await load();
          };
        });

        document.addEventListener('astro:page-load', () => {
          if (!navigating) return;
          navigating = false;
          finishBar();
        });
      }
    </script>
  </body>
</html>
