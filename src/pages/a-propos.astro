---
import { Image } from 'astro:assets';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { siteConfig } from '@/lib/site-config';
import lacPhoto from '@/assets/lac-du-bourget.jpg';

const stats = [
  { value: '2023', label: 'Création' },
  { value: 'Entrelacs', label: 'Siège social (Savoie)' },
  { value: 'TPE/PME', label: 'Notre cible' },
] as const;
---

<BaseLayout
  title="À propos"
  description="2 LACS Informatique, votre partenaire IT de proximité en Savoie, entre lac du Bourget et lac d'Annecy. Créée en 2023 par Christophe REVOIRE."
  path="/a-propos"
>
  <section class="mx-auto max-w-6xl px-6 py-16 sm:py-20">
    <div class="grid items-center gap-12 lg:grid-cols-2">
      <div>
        <p class="text-sm font-semibold tracking-wide text-brand-600 uppercase">
          À propos de l'entreprise
        </p>
        <h1 class="mt-3 text-3xl font-bold tracking-tight text-brand-900 sm:text-4xl">
          Votre partenaire informatique de proximité
        </h1>
        <p class="mt-6 leading-relaxed text-brand-900/80">
          Entre le lac du Bourget et le lac d'Annecy, 2 LACS Informatique est spécialisée dans la
          prestation de services informatiques dédiés aux TPE/PME. Notre objectif premier :
          accompagner nos clients dans leur développement en leur fournissant des solutions
          technologiques adaptées à leurs besoins spécifiques.
        </p>
        <p class="mt-4 leading-relaxed text-brand-900/80">
          Avec des compétences diversifiées, nous nous concentrons sur l'infrastructure systèmes et
          réseaux, afin que nos clients disposent d'une base solide et fiable pour leur activité.
          Conscients de l'importance grandissante du cloud, nous proposons également des solutions
          de cloud computing sur mesure, pour bénéficier de toute la flexibilité et de la
          scalabilité de cette technologie.
        </p>
      </div>

      <figure class="overflow-hidden rounded-2xl shadow-md">
        <Image
          src={lacPhoto}
          alt="Vue sur le lac du Bourget, en Savoie"
          widths={[480, 768, 1024]}
          sizes="(max-width: 1024px) 100vw, 50vw"
          class="h-full w-full object-cover"
        />
        <figcaption class="bg-brand-900 px-4 py-2 text-center text-xs text-white/70">
          Entre lac du Bourget et lac d'Annecy — notre territoire.
        </figcaption>
      </figure>
    </div>

    <!-- Repères -->
    <dl class="mt-16 grid gap-6 sm:grid-cols-3">
      {
        stats.map((s) => (
          <div class="rounded-xl border border-brand-100 bg-brand-50 px-6 py-8 text-center">
            <dt class="sr-only">{s.label}</dt>
            <dd class="text-3xl font-bold text-brand-700">{s.value}</dd>
            <dd class="mt-1 text-sm text-brand-900/60">{s.label}</dd>
          </div>
        ))
      }
    </dl>
  </section>

  <!-- Pourquoi nous -->
  <section class="bg-brand-50">
    <div class="mx-auto max-w-4xl px-6 py-16">
      <h2 class="text-2xl font-bold tracking-tight text-brand-900">Pourquoi nous ?</h2>
      <p class="mt-5 leading-relaxed text-brand-900/80">
        Nous mettons tout en œuvre pour offrir des services de qualité supérieure, une expertise
        approfondie et des solutions personnalisées qui aident nos clients à atteindre leurs
        objectifs informatiques et à prospérer dans un environnement technologique en constante
        évolution.
      </p>
      <p class="mt-4 leading-relaxed text-brand-900/80">
        Nous mettons à votre service nos compétences informatiques et notre réactivité pour assurer
        votre réussite. Fournir les bonnes solutions peut vous permettre de franchir des étapes
        importantes et d'atteindre de nouveaux sommets.
      </p>
    </div>
  </section>

  <!-- L'équipe -->
  <section class="mx-auto max-w-4xl px-6 py-16">
    <h2 class="text-2xl font-bold tracking-tight text-brand-900">La team</h2>
    <div
      class="mt-8 flex flex-col items-start gap-4 rounded-2xl border border-brand-100 p-6 sm:flex-row sm:items-center sm:gap-6"
    >
      <span
        class="flex h-16 w-16 shrink-0 items-center justify-center rounded-full bg-brand-600 text-xl font-bold text-white"
        aria-hidden="true"
      >
        CR
      </span>
      <div class="flex-1">
        <p class="text-lg font-semibold text-brand-900">Christophe REVOIRE</p>
        <p class="text-sm text-brand-900/60">Fondateur &amp; dirigeant</p>
      </div>
      <ul class="flex gap-4 text-sm">
        {
          siteConfig.social.map((s) => (
            <li>
              <a class="text-brand-600 hover:underline" href={s.href} rel="noopener">
                {s.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-gradient-to-br from-brand-700 to-brand-600 text-white">
    <div class="mx-auto max-w-4xl px-6 py-16 text-center">
      <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">Travaillons ensemble</h2>
      <p class="mx-auto mt-4 max-w-xl text-white/90">
        Un projet, une question ? Nous serons ravis d'échanger avec vous.
      </p>
      <a
        href="/contact"
        class="mt-8 inline-block rounded-lg bg-white px-6 py-3 text-sm font-semibold text-brand-700 shadow-sm transition hover:bg-brand-50"
      >
        Nous contacter
      </a>
    </div>
  </section>
</BaseLayout>
