---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero.astro';
import ServiceCard from '@/components/ServiceCard.astro';
import { getServices, serviceHref } from '@/lib/services';
import { partners } from '@/lib/partners';

const services = await getServices();
---

<BaseLayout>
  <Hero
    subtitle="Spécialistes des services informatiques pour les TPE/PME, entre lac du Bourget et lac d'Annecy : infrastructure, cloud, cybersécurité et support."
  />

  <!-- Services -->
  <section id="services" class="scroll-mt-20 bg-surface">
    <div class="mx-auto max-w-6xl px-6 py-20 sm:py-24">
      <div class="flex flex-wrap items-end justify-between gap-4">
        <div>
          <p class="eyebrow">Nos prestations</p>
          <h2 class="mt-3 text-3xl font-bold tracking-tight text-content sm:text-4xl">
            Un partenaire, tous vos besoins IT
          </h2>
          <p class="mt-3 max-w-2xl text-muted">
            De l'audit au support quotidien — concevoir, déployer, sécuriser et maintenir votre
            système d'information.
          </p>
        </div>
        <a
          href="/services"
          class="group inline-flex items-center gap-1.5 text-sm font-semibold text-accent-600"
        >
          Tous nos services
          <span
            class="transition-transform duration-300 group-hover:translate-x-1"
            aria-hidden="true">→</span
          >
        </a>
      </div>

      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          services.map((s) => (
            <ServiceCard
              title={s.data.title}
              summary={s.data.summary}
              href={serviceHref(s.id)}
              icon={s.data.icon}
            />
          ))
        }
      </div>
    </div>
  </section>

  <!-- Engagement — bande navy -->
  <section class="relative isolate overflow-hidden bg-brand-900 text-paper">
    <div class="topo absolute inset-0"></div>
    <div class="glow-sunset absolute inset-0"></div>
    <div class="relative mx-auto max-w-4xl px-6 py-24 text-center">
      <p
        class="inline-flex items-center gap-2 text-xs font-semibold tracking-[0.14em] text-paper/55 uppercase"
      >
        <span class="h-2 w-2 -skew-x-12 bg-accent-400"></span>
        Notre engagement
      </p>
      <h2 class="mt-4 text-3xl font-bold tracking-tight text-balance sm:text-4xl">
        Votre réussite est <span class="text-sunset">notre priorité</span>
      </h2>
      <p class="mx-auto mt-6 max-w-2xl leading-relaxed text-paper/75">
        Nous fournissons des solutions sur mesure et vous aidons à déployer rapidement les outils
        dont vous avez besoin. L'informatique et le numérique sont stratégiques : les bonnes
        solutions vous permettent de franchir des étapes importantes et d'atteindre de nouveaux
        sommets.
      </p>
    </div>
  </section>

  <!-- Partenaires -->
  <section class="bg-panel">
    <div class="mx-auto max-w-6xl px-6 py-16">
      <p class="text-center text-xs font-semibold tracking-[0.14em] text-muted uppercase">
        Nos partenaires technologiques
      </p>
      <ul class="mt-8 flex flex-wrap items-center justify-center gap-x-10 gap-y-6">
        {
          partners.map((p) => (
            <li>
              <img
                src={p.logo}
                alt={p.name}
                height="28"
                loading="lazy"
                decoding="async"
                class="h-7 w-auto opacity-60 grayscale transition duration-300 hover:opacity-100 dark:opacity-70 dark:invert dark:hover:opacity-100"
              />
            </li>
          ))
        }
      </ul>
      <p class="mt-8 text-center">
        <a
          href="/partenaires"
          class="group inline-flex items-center gap-1.5 text-sm font-semibold text-accent-600"
        >
          Découvrir nos partenaires
          <span
            class="transition-transform duration-300 group-hover:translate-x-1"
            aria-hidden="true">→</span
          >
        </a>
      </p>
    </div>
  </section>

  <!-- CTA — bande sunset -->
  <section class="bg-gradient-to-br from-accent-300 via-accent-400 to-accent-600">
    <div class="mx-auto max-w-4xl px-6 py-20 text-center text-brand-900">
      <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">Prêt à nous rejoindre ?</h2>
      <p class="mx-auto mt-4 max-w-xl font-medium text-brand-900/80">
        N'hésitez pas à prendre contact avec nous pour tous types de projet.
      </p>
      <a
        href="/contact"
        class="mt-8 inline-block rounded-full bg-brand-900 px-7 py-3 text-sm font-semibold text-paper shadow-lg shadow-brand-900/20 transition hover:bg-brand-800"
      >
        Contactez-nous
      </a>
    </div>
  </section>
</BaseLayout>
