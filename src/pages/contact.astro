---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { siteConfig } from '@/lib/site-config';

// Feedback sans JS : contact.php redirige vers ?sent=1 ou ?error=1.
const status = Astro.url.searchParams.get('sent')
  ? 'sent'
  : Astro.url.searchParams.get('error')
    ? 'error'
    : null;
---

<BaseLayout
  title="Contact"
  description="Contactez 2 LACS Informatique pour vos projets IT."
  path="/contact"
>
  <section class="mx-auto max-w-2xl px-6 py-20">
    <h1 class="text-3xl font-bold tracking-tight text-brand-900">Contact</h1>
    <p class="mt-3 text-brand-900/70">
      Une question, un projet ? Écrivez-nous, nous revenons vers vous rapidement.
    </p>

    {
      status === 'sent' && (
        <p class="mt-6 rounded-lg bg-accent-400/15 px-4 py-3 text-sm text-brand-700">
          Merci, votre message a bien été envoyé.
        </p>
      )
    }
    {
      status === 'error' && (
        <p class="mt-6 rounded-lg bg-red-50 px-4 py-3 text-sm text-red-700">
          Une erreur est survenue. Réessayez ou écrivez-nous à {siteConfig.contact.email}.
        </p>
      )
    }

    <form method="POST" action="/contact.php" class="mt-8 grid gap-5">
      <!-- Honeypot anti-spam : masqué aux humains, rempli par les bots. -->
      <input
        type="text"
        name="website"
        tabindex="-1"
        autocomplete="off"
        class="hidden"
        aria-hidden="true"
      />

      <div class="grid gap-5 sm:grid-cols-2">
        <label class="grid gap-1 text-sm font-medium text-brand-900">
          Nom
          <input
            type="text"
            name="name"
            required
            class="rounded-lg border border-brand-100 px-3 py-2 focus:border-brand-500 focus:outline-none"
          />
        </label>

        <label class="grid gap-1 text-sm font-medium text-brand-900">
          Prénom
          <input
            type="text"
            name="prenom"
            class="rounded-lg border border-brand-100 px-3 py-2 focus:border-brand-500 focus:outline-none"
          />
        </label>
      </div>

      <div class="grid gap-5 sm:grid-cols-2">
        <label class="grid gap-1 text-sm font-medium text-brand-900">
          Email
          <input
            type="email"
            name="email"
            required
            class="rounded-lg border border-brand-100 px-3 py-2 focus:border-brand-500 focus:outline-none"
          />
        </label>

        <label class="grid gap-1 text-sm font-medium text-brand-900">
          Entreprise
          <input
            type="text"
            name="entreprise"
            class="rounded-lg border border-brand-100 px-3 py-2 focus:border-brand-500 focus:outline-none"
          />
        </label>
      </div>

      <label class="grid gap-1 text-sm font-medium text-brand-900">
        Message
        <textarea
          name="message"
          rows="6"
          required
          class="rounded-lg border border-brand-100 px-3 py-2 focus:border-brand-500 focus:outline-none"
        ></textarea>
      </label>

      <button
        type="submit"
        class="justify-self-start rounded-lg bg-brand-600 px-6 py-3 text-sm font-semibold text-white transition hover:bg-brand-700"
      >
        Envoyer
      </button>
    </form>
  </section>
</BaseLayout>
