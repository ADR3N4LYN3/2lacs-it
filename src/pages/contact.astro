---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { siteConfig } from '@/lib/site-config';

// Feedback sans JS : contact.php redirige vers ?sent=1 ou ?error=1.
const status = Astro.url.searchParams.get('sent')
  ? 'sent'
  : Astro.url.searchParams.get('error')
    ? 'error'
    : null;

const field =
  'rounded-lg border border-edge bg-card px-3 py-2 text-content placeholder:text-muted focus:border-accent-400 focus:outline-none';
---

<BaseLayout
  title="Contact"
  description="Contactez 2 LACS Informatique pour vos projets IT."
  path="/contact"
>
  <section class="mx-auto max-w-2xl px-6 py-16 sm:py-20">
    <p class="eyebrow">Parlons-en</p>
    <h1 class="mt-3 text-3xl font-bold tracking-tight text-content sm:text-4xl">Contact</h1>
    <p class="mt-3 text-muted">
      Une question, un projet ? Écrivez-nous, nous revenons vers vous rapidement.
    </p>

    {
      status === 'sent' && (
        <p class="mt-6 rounded-lg border border-accent-400/30 bg-accent-400/15 px-4 py-3 text-sm text-content">
          Merci, votre message a bien été envoyé.
        </p>
      )
    }
    {
      status === 'error' && (
        <p class="mt-6 rounded-lg bg-red-50 px-4 py-3 text-sm text-red-700 dark:bg-red-950/40 dark:text-red-300">
          Une erreur est survenue. Réessayez ou écrivez-nous à {siteConfig.contact.email}.
        </p>
      )
    }

    <form method="POST" action="/contact.php" data-astro-reload class="mt-8 grid gap-5">
      <!-- Honeypot anti-spam : masqué aux humains, rempli par les bots. -->
      <input
        type="text"
        name="website"
        tabindex="-1"
        autocomplete="off"
        class="hidden"
        aria-hidden="true"
      />

      <div class="grid gap-5 sm:grid-cols-2">
        <label class="grid gap-1 text-sm font-medium text-content">
          Nom
          <input type="text" name="name" required class={field} />
        </label>

        <label class="grid gap-1 text-sm font-medium text-content">
          Prénom
          <input type="text" name="prenom" class={field} />
        </label>
      </div>

      <div class="grid gap-5 sm:grid-cols-2">
        <label class="grid gap-1 text-sm font-medium text-content">
          Email
          <input type="email" name="email" required class={field} />
        </label>

        <label class="grid gap-1 text-sm font-medium text-content">
          Entreprise
          <input type="text" name="entreprise" class={field} />
        </label>
      </div>

      <label class="grid gap-1 text-sm font-medium text-content">
        Message
        <textarea name="message" rows="6" required class={field}></textarea>
      </label>

      <button
        type="submit"
        class="justify-self-start rounded-full bg-gradient-to-r from-accent-300 via-accent-400 to-accent-600 px-7 py-3 text-sm font-semibold text-brand-900 shadow-lg shadow-accent-500/20 transition hover:brightness-105"
      >
        Envoyer
      </button>
    </form>
  </section>
</BaseLayout>
