---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import ServiceCard from '@/components/ServiceCard.astro';
import { getServices, serviceHref } from '@/lib/services';

export async function getStaticPaths() {
  const services = await getCollection('services');
  return services.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const others = (await getServices()).filter((s) => s.id !== entry.id).slice(0, 3);
---

<BaseLayout title={entry.data.title} description={entry.data.summary} path={serviceHref(entry.id)}>
  <article class="mx-auto max-w-3xl px-6 py-16 sm:py-20">
    <nav class="text-sm text-brand-900/60" aria-label="Fil d'Ariane">
      <a class="hover:text-brand-600" href="/services">Services</a>
      <span class="mx-2" aria-hidden="true">/</span>
      <span class="text-brand-900/80">{entry.data.title}</span>
    </nav>

    <h1 class="mt-4 text-3xl font-bold tracking-tight text-brand-900 sm:text-4xl">
      {entry.data.title}
    </h1>
    <p class="mt-4 text-lg leading-relaxed text-brand-900/70">{entry.data.summary}</p>

    <div class="rich-text mt-10">
      <Content />
    </div>

    <div class="mt-12 rounded-xl bg-brand-50 px-6 py-8 text-center">
      <p class="text-lg font-semibold text-brand-900">Un projet, une question ?</p>
      <p class="mt-2 text-sm text-brand-900/70">
        Parlons de vos besoins — nous revenons vers vous rapidement.
      </p>
      <a
        href="/contact"
        class="mt-5 inline-block rounded-lg bg-brand-600 px-6 py-3 text-sm font-semibold text-white transition hover:bg-brand-700"
      >
        Nous contacter
      </a>
    </div>
  </article>

  <section class="border-t border-brand-100 bg-white">
    <div class="mx-auto max-w-6xl px-6 py-16">
      <h2 class="text-2xl font-bold tracking-tight text-brand-900">Nos autres services</h2>
      <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          others.map((s) => (
            <ServiceCard
              title={s.data.title}
              summary={s.data.summary}
              href={serviceHref(s.id)}
              icon={s.data.icon}
            />
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
