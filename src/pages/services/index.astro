---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ServiceCard from '@/components/ServiceCard.astro';
import { getServices, serviceHref } from '@/lib/services';

const services = await getServices();
---

<BaseLayout
  title="Services"
  description="Audit, intégration, infogérance, cybersécurité, support et monitoring : un partenaire unique pour votre système d'information."
  path="/services"
>
  <section class="mx-auto max-w-6xl px-6 py-16 sm:py-20">
    <p class="eyebrow">Nos prestations</p>
    <h1 class="mt-3 text-3xl font-bold tracking-tight text-content sm:text-4xl">Nos services</h1>
    <p class="mt-4 max-w-2xl text-lg text-muted">
      Un partenaire unique pour concevoir, déployer, sécuriser et maintenir votre système
      d'information — de l'audit jusqu'au support au quotidien.
    </p>

    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        services.map((s) => (
          <ServiceCard
            title={s.data.title}
            summary={s.data.summary}
            href={serviceHref(s.id)}
            icon={s.data.icon}
          />
        ))
      }
    </div>
  </section>
</BaseLayout>
