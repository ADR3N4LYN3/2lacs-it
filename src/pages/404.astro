---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Page introuvable" path="/404">
  <section class="mx-auto max-w-2xl px-6 py-32 text-center">
    <p class="font-display text-7xl font-bold text-sunset">404</p>
    <h1 class="mt-4 text-2xl font-bold text-content">Cette page n'existe pas</h1>
    <p class="mt-3 text-muted">La page que vous cherchez a peut-être été déplacée.</p>
    <a
      href="/"
      class="mt-8 inline-block rounded-full bg-content px-6 py-3 text-sm font-semibold text-surface transition hover:opacity-90"
    >
      Retour à l'accueil
    </a>
  </section>
</BaseLayout>
