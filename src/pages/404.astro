---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Page introuvable" path="/404">
  <section class="mx-auto max-w-2xl px-6 py-32 text-center">
    <p class="text-6xl font-bold text-brand-300">404</p>
    <h1 class="mt-4 text-2xl font-bold text-brand-900">Cette page n'existe pas</h1>
    <a
      href="/"
      class="mt-8 inline-block rounded-lg bg-brand-600 px-6 py-3 text-sm font-semibold text-white transition hover:bg-brand-700"
    >
      Retour à l'accueil
    </a>
  </section>
</BaseLayout>
